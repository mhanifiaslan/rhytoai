rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ---------- Kullanıcı profilleri ----------
    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
          'uid', 'displayName', 'photoUrl', 'email',
          'birthDate', 'birthTime', 'birthCity', 'birthNation', 'gender',
          'sunSign', 'moonSign', 'ascendant', 'wuXingElement', 'mizac',
          'onboardingCompleted', 'createdAt', 'updatedAt', 'fcmToken', 'bio'
        ]);
      allow delete: if isOwner(uid);

      // Takip sistemi (X modeli):
      // following/{targetUid} -> profil sahibi yazar
      match /following/{targetUid} {
        allow read: if signedIn();
        allow create, delete: if isOwner(uid);
      }
      // followers/{followerUid} -> takip eden kişi yazar
      match /followers/{followerUid} {
        allow read: if signedIn();
        allow create, delete: if signedIn() && request.auth.uid == followerUid;
      }

      // Engellenen kullanıcılar: yalnızca liste sahibi yazar/siler/okur
      match /blocked/{targetUid} {
        allow read, create, delete: if isOwner(uid);
      }
    }

    // ---------- Şikayetler (yalnızca konsoldan incelenir) ----------
    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.targetType in ['post', 'user']
        && request.resource.data.targetId is string
        && request.resource.data.targetId.size() > 0
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500;
      allow read, update, delete: if false;
    }

    // ---------- Gönderiler (kişisel akış + kanal gönderileri) ----------
    match /posts/{postId} {
      function isChannelOwner() {
        return get(/databases/$(database)/documents/channels/$(request.resource.data.channelId)).data.ownerId == request.auth.uid;
      }

      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        // Kanal gönderisini yalnızca kanal sahibi atabilir
        && (!('channelId' in request.resource.data)
            || request.resource.data.channelId == null
            || isChannelOwner());
      allow update, delete: if signedIn()
        && resource.data.authorId == request.auth.uid;

      match /likes/{uid} {
        allow read: if signedIn();
        allow create, delete: if isOwner(uid);
      }

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text.size() <= 1000;
        allow delete: if signedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    // ---------- Kanallar (tek yönlü yayın) ----------
    match /channels/{channelId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 60;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      match /subscribers/{uid} {
        allow read: if signedIn();
        allow create, delete: if isOwner(uid);
      }
    }

    // ---------- Birebir mesajlaşma (DM) ----------
    match /chats/{chatId} {
      function isParticipant() {
        return signedIn() && request.auth.uid in resource.data.participants;
      }
      function willBeParticipant() {
        return signedIn() && request.auth.uid in request.resource.data.participants;
      }

      allow read: if isParticipant();
      allow create: if willBeParticipant()
        && request.resource.data.participants.size() == 2;
      allow update: if isParticipant() && willBeParticipant();
      allow delete: if false;

      match /messages/{messageId} {
        function parentChat() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data;
        }
        allow read: if signedIn() && request.auth.uid in parentChat().participants;
        allow create: if signedIn()
          && request.auth.uid in parentChat().participants
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text.size() <= 4000;
        allow update, delete: if false;
      }
    }
  }
}
